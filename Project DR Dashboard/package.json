{
  "name": "dr-command-center",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:api": "npm --workspace apps/api run dev",
    "dev:webhook": "npm --workspace apps/webhook run dev",
    "dev:worker": "npm --workspace apps/worker run dev",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "build": "npm --workspaces --if-present run build",
    "eval:chatbot": "node scripts/eval_chatbot.mjs",
    "kb:audit": "node scripts/kb_audit.mjs",
    "kb:daily-ingest": "node scripts/daily_ingest_runner.mjs",
    "kb:import:research-dataset": "python3 scripts/import_research_dataset.py",
    "kb:import:settrade-dividends": "node scripts/import_settrade_dividends.mjs",
    "kb:import:settrade-bundle": "node scripts/import_settrade_bundle.mjs",
    "kb:seed:underlying-identity": "python3 scripts/seed_underlying_identity_master.py",
    "kb:audit:yahoo-resolution": "python3 scripts/audit_yahoo_symbol_resolution.py",
    "kb:import:yfinance": "python3 scripts/import_yfinance_underlyings.py",
    "kb:import:yahoo-news": "python3 scripts/import_yahoo_finance_news.py",
    "kb:import:finnhub-thai-dr": "python3 scripts/import_finnhub_thai_dr_kb.py",
    "kb:audit:underlying-news": "node scripts/audit_underlying_news_quality.mjs",
    "kb:import:sec-edgar": "python3 scripts/import_sec_edgar_underlyings.py",
    "kb:ingest:job-runs": "python3 scripts/ingest_underlying_job_runs.py",
    "kb:scaffold:underlying": "python3 scripts/scaffold_underlying_coverage.py",
    "kb:build:underlying": "python3 scripts/build_underlying_enrichment.py",
    "kb:build:dr-market-snapshots": "python3 scripts/build_dr_market_snapshots.py",
    "kb:build:fetch-plan": "python3 scripts/build_underlying_fetch_plan.py",
    "underlying:plan": "python3 scripts/build_underlying_fetch_plan.py",
    "underlying:check-config": "node scripts/check_provider_config.mjs",
    "underlying:probe-providers": "node scripts/probe_provider_endpoints.mjs",
    "underlying:fetch-sample": "node scripts/fetch_underlying_provider_sample.mjs",
    "underlying:enqueue-job": "node scripts/enqueue_underlying_job.mjs",
    "underlying:register-schedules": "node scripts/register_underlying_schedules.mjs",
    "underlying:schedules:status": "docker compose exec worker node /app/scripts/manage_underlying_schedules.mjs --action=status",
    "underlying:schedules:pause": "docker compose exec worker node /app/scripts/manage_underlying_schedules.mjs --action=pause-queue",
    "underlying:schedules:resume": "docker compose exec worker node /app/scripts/manage_underlying_schedules.mjs --action=resume-queue",
    "underlying:schedules:remove": "docker compose exec worker node /app/scripts/manage_underlying_schedules.mjs --action=remove-schedule",
    "underlying:schedules:remove-all": "docker compose exec worker node /app/scripts/manage_underlying_schedules.mjs --action=remove-all",
    "underlying:schedules:report": "docker compose exec worker node /app/scripts/report_underlying_schedules.mjs",
    "underlying:job:finnhub": "node scripts/jobs/finnhub_freshness_job.mjs",
    "underlying:job:fmp": "node scripts/jobs/fmp_rotation_job.mjs",
    "underlying:job:eodhd": "node scripts/jobs/eodhd_repair_job.mjs",
    "underlying:job:twelvedata": "node scripts/jobs/twelvedata_price_job.mjs",
    "underlying:job:bot-fx": "node scripts/jobs/bot_fx_job.mjs",
    "contract:validate:dashboard-feed": "node scripts/validate_dashboard_feed_contract.mjs",
    "contract:report:dashboard-feed": "node scripts/validate_dashboard_feed_contract.mjs --limit 500 --out reports/dashboard_feed_contract_validation.json"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.6.3"
  }
}
